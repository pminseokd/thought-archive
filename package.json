{
  "name": "thought-archive",
  "version": "1.0.1",
  "description": "Thought Archive — local note & resource manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-packager . \"Thought Archive\" --platform=win32 --arch=x64 --out=dist --overwrite --app-version=1.0.1 --ignore=\"/dist($|/)\" --ignore=\"/error-log\\.md$\" --ignore=\"/.git($|/)\""
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^35.0.0",
    "playwright-core": "^1.60.0"
  }
}
